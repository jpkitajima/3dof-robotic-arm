<?xml version="1.0"?>
<robot name="visual">

<material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <link name="base_link">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0.37"/>
      <geometry>
        <mesh filename="package://robot_arm/meshes/link0.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <link name="link1">
    <visual>
      <origin rpy="1.57075 0 0" xyz="-0.2 0.05 0.125"/>
      <geometry>
        <mesh filename="package://robot_arm/meshes/link1.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="base_to_link1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0.1011 -0.1236 0.37"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <link name="link2">
    <visual>
      <origin rpy="1.57075 0 0" xyz="-1.3 0.2 -1.2"/>
      <geometry>
        <mesh filename="package://robot_arm/meshes/link2.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="link1_to_link2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.235 0.45 1.35"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <link name="link3">
    <visual>
      <origin rpy="-1.57075 3.14159 0" xyz="0.15 -0.2 -1.2"/>
      <geometry>
        <mesh filename="package://robot_arm/meshes/link3.stl" scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="link2_to_link3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="-1.325 -0.3 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

</robot>
